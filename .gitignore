# transient run logs (tee'd output from connect/onboarding runs)
outputs/_*.log

# per-query dossiers generated on demand by `connect dossier --html`
outputs/dossier_*.html

# python bytecode
__pycache__/
*.pyc

# dev/test caches
.pytest_cache/

# office lock/temp files (created while an .xlsx is open)
~$*

# DR exports of the control plane (scripts/export_control_plane.py) — backups, never commit
backups/
