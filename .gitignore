# transient run logs (tee'd output from connect/onboarding runs)
outputs/_*.log

# heartbeat runtime state + lock (scripts/heartbeat.py) — machine-local, never commit
outputs/_heartbeat_state.json
outputs/_heartbeat.lock
outputs/_heartbeat_selftest*.lock
outputs/_heartbeat_selftest*.pid

# per-query dossiers generated on demand by `connect dossier --html`
outputs/dossier_*.html

# python bytecode
__pycache__/
*.pyc

# dev/test caches
.pytest_cache/

# office lock/temp files (created while an .xlsx is open)
~$*

# DR exports of the control plane (scripts/export_control_plane.py) — backups, never commit
backups/

# Secrets — never commit (belt-and-suspenders; the live .env lives in library-onboarding/)
.env
*.env
!.env.example

# Wholesale-regenerated CONNECT artifacts — rebuilt by `python -m connect all`;
# don't churn 30MB+ through git (the reading room reads connect_graph.json off disk).
outputs/connect_graph.json
outputs/connect_fingerprints.json
outputs/connection_explorer.html

# Pour run logs — append-only console output, 50k+ lines per run; never track
library-onboarding/*.log
# Scheduled-task heartbeat state (runtime, machine-local)
outputs/_task_*_LAST.json
outputs/_task_*_out.txt
