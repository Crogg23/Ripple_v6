  236     # IRS 990 XML uses namespaces; strip them for easier access
  237     def _strip_ns(tag):
  238         return re.sub(r'\{[^}]+\}', '', tag)
  239 
  240     def _find(node, *paths):
  241         """Try multiple tag paths, return first match text or ''."""
  242         for path in paths:
  243             parts = path.split("/")
  244             cur = node
  245             for p in parts:
  246                 found = None
  247                 for child in cur:
  248                     if _strip_ns(child.tag) == p:
  249                         found = child
  250                         break
  251                 if found is None:
  252                     cur = None
  253                     break
  254                 cur = found
  255             if cur is not None and cur.text:
  256                 return cur.text.strip()
  257         return ""
  258 
  259     def _find_all(node):
  260         """Flatten entire XML tree into a dict keyed by stripped tag."""
  261         result = {}
  262         def _recurse(n, prefix=""):
  263             tag = _strip_ns(n.tag)
  264             key = f"{prefix}/{tag}".lstrip("/")
  265             if n.text and n.text.strip():
  266                 result[key] = n.text.strip()
  267             for child in n:
  268                 _recurse(child, key)
  269         _recurse(node)
  270         return result
  271 
  272     flat = _find_all(root)
  273 
