   87             continue
   88         row = {}
   89         for pos, col in field_map.items():
   90             row[col] = parts[pos].strip() if pos < len(parts) else ""
   91         rows.append(row)
   92     if not rows:
   93         return pd.DataFrame(columns=list(field_map.values()))
   94     return pd.DataFrame(rows)
