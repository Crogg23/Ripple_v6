# ---------------------------------------------------------------------------
# Source Onboarding Agent -- environment template
#
# Copy to `.env` and fill in the blanks. `.env` is gitignored; NEVER commit
# real credentials. Leave a value blank to use the default shown in comments.
# ---------------------------------------------------------------------------

# --- Anthropic (required for real recon / codegen) -------------------------
ANTHROPIC_API_KEY=
# Optional. Defaults to claude-sonnet-4-6. Set a more capable model for
# higher-quality recon and code generation.
ANTHROPIC_MODEL=

# --- Snowflake (required for the LOAD checkpoint) --------------------------
SNOWFLAKE_ACCOUNT=ONEAFDA-UMB20733
SNOWFLAKE_USER=CROGG23
SNOWFLAKE_PASSWORD=
SNOWFLAKE_DATABASE=DISASTER_IMPACT
SNOWFLAKE_SCHEMA=RAW
# Optional but recommended -- a warehouse must be set for writes to run.
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_ROLE=
# Raw table layout: schema_per_source (default) -> DISASTER_IMPACT.<SOURCE>.<TABLE>
#                   single_schema             -> DISASTER_IMPACT.RAW.<SOURCE>_<TABLE>
SNOWFLAKE_RAW_LAYOUT=schema_per_source

# --- OpenMetadata (required for the CATALOG checkpoint) --------------------
OPENMETADATA_HOST=http://localhost:8585
# Get this from localhost:8585 -> Settings -> Bots/Users -> Access Token.
OPENMETADATA_TOKEN=

# --- dbt (required for the DBT checkpoint) ---------------------------------
# Absolute path to the directory containing your dbt_project.yml.
DBT_PROJECT_PATH=

# --- Agent behaviour (testing only) ----------------------------------------
# ONBOARD_FAKE_LLM=1 returns canned recon/codegen so the flow runs offline.
ONBOARD_FAKE_LLM=
# ONBOARD_AUTO_APPROVE=1 auto-answers every checkpoint with "go" (smoke tests).
ONBOARD_AUTO_APPROVE=
