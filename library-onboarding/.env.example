# ---------------------------------------------------------------------------
# Ripple Source Onboarding Agent -- environment template
#
# Copy to `.env` and fill in the blanks. `.env` is gitignored; NEVER commit
# real credentials. Blank values fall back to the defaults shown in comments.
# ---------------------------------------------------------------------------

# --- Anthropic (required for real recon / codegen) -------------------------
ANTHROPIC_API_KEY=
# Optional. Defaults to claude-sonnet-4-6. Set a more capable model for
# higher-quality recon and code generation.
ANTHROPIC_MODEL=

# --- Snowflake connection (required for LOAD + REGISTRY) -------------------
SNOWFLAKE_ACCOUNT=ONEAFDA-UMB20733
SNOWFLAKE_USER=CROGG23
SNOWFLAKE_PASSWORD=
# A warehouse MUST be set for any write to run.
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_ROLE=

# --- Ripple warehouse layout (defaults match the live account) -------------
# Raw landing: LIBRARY_RAW.LANDING.<UPPER(SOURCE_ID)>
RIPPLE_RAW_DATABASE=LIBRARY_RAW
RIPPLE_RAW_SCHEMA=LANDING
# Catalog + run logs live in LIBRARY_META
RIPPLE_META_DATABASE=LIBRARY_META
RIPPLE_REGISTRY_SCHEMA=REGISTRY
RIPPLE_REGISTRY_TABLE=SOURCE_REGISTRY
RIPPLE_INGEST_LOG_SCHEMA=INGEST_LOGS
RIPPLE_INGEST_LOG_TABLE=INGEST_RUNS
# dbt output databases
RIPPLE_STAGING_DATABASE=LIBRARY_STAGING
RIPPLE_MARTS_DATABASE=LIBRARY_MARTS

# --- dbt (required for the DBT checkpoint) ---------------------------------
# Absolute path to the directory containing your dbt_project.yml.
DBT_PROJECT_PATH=

# --- Agent behaviour -------------------------------------------------------
# Skip reloading a source whose content hash matches its last successful run.
ONBOARD_SKIP_IF_UNCHANGED=1
# ONBOARD_FAKE_LLM=1 returns canned recon/codegen AND skips Snowflake writes
# so the flow runs fully offline. Testing/demos only.
ONBOARD_FAKE_LLM=
# ONBOARD_AUTO_APPROVE=1 auto-answers every checkpoint with "go" (smoke tests).
ONBOARD_AUTO_APPROVE=

# --- Headless browser (C1b -- only for scrape_js sources) ------------------
# Needs Playwright + a browser binary (optional, heavy ~170 MB):
#     pip install playwright && playwright install chromium
# Run headless (set 0 only to watch the browser locally while debugging).
ONBOARD_BROWSER_HEADLESS=1
# Per-step timeout (navigation / selector wait), milliseconds.
ONBOARD_BROWSER_TIMEOUT_MS=45000
# page.goto navigation milestone (domcontentloaded is reliable; a bounded
# networkidle wait happens afterwards).
ONBOARD_BROWSER_WAIT_UNTIL=domcontentloaded
# Accept untrusted TLS certs (default on -- needed behind TLS-intercepting proxies).
ONBOARD_BROWSER_IGNORE_HTTPS_ERRORS=1
# If you installed browsers to a custom dir, point Playwright at it:
# PLAYWRIGHT_BROWSERS_PATH=/opt/pw-browsers
