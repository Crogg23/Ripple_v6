        place_of_performance_fips,
        recipient_location_fips,

        -- -------------------------------------------------------
        -- Recipient & agency descriptors
        -- -------------------------------------------------------
        recipient_name,
        awarding_agency_name,
        funding_agency_name,
        naics_description,
        cfda_title,

        -- -------------------------------------------------------
        -- Award classification
        -- -------------------------------------------------------
        award_type,
        def_code,
        fiscal_year,

